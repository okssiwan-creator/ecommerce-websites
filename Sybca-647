<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Daily Crunch | Fast Food Show</title>
    <style>
        /* --- RESET & VARIABLES --- */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        :root {
            --bg-color: #121212;
            --card-bg: #1e1e1e;
            --primary: #FFB800; /* Burger Gold */
            --secondary: #E50914; /* Ketchup Red */
            --text-color: #ffffff;
            --text-muted: #aaaaaa;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            line-height: 1.6;
        }

        /* --- UTILITIES --- */
        .container {
            width: 85%;
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem 0;
        }
        .btn {
            display: inline-block;
            padding: 0.8rem 1.5rem;
            border: none;
            border-radius: 5px;
            font-weight: bold;
            text-transform: uppercase;
            cursor: pointer;
            text-decoration: none;
            transition: transform 0.2s, background 0.2s;
        }
        .btn-primary { background-color: var(--primary); color: #000; }
        .btn-secondary { background-color: transparent; border: 2px solid var(--text-color); color: var(--text-color); }
        .btn:hover { transform: scale(1.05); }

        /* --- HEADER & HERO --- */
        header {
            background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.9)), url('https://images.unsplash.com/photo-1561758033-d89a9ad46330?q=80&w=1200') no-repeat center center/cover;
            padding: 6rem 0;
            text-align: center;
            border-bottom: 5px solid var(--primary);
        }
        header h1 {
            font-size: 4rem;
            color: var(--primary);
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 0.5rem;
            text-shadow: 3px 3px 0px var(--secondary);
        }
        header p {
            font-size: 1.2rem;
            font-style: italic;
            color: var(--text-muted);
            margin-bottom: 2rem;
        }
        .hero-buttons {
            display: flex;
            justify-content: center;
            gap: 1rem;
            flex-wrap: wrap;
        }

        /* --- FEATURED SECTION --- */
        .featured-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 2rem;
            margin-top: 2rem;
        }
        @media (max-width: 768px) {
            .featured-grid { grid-template-columns: 1fr; }
        }
        .video-player {
            background: #000;
            aspect-ratio: 16/9;
            border-radius: 8px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            border: 2px solid #333;
            position: relative;
        }
        .play-btn {
            font-size: 3rem;
            color: var(--primary);
            cursor: pointer;
        }
        .video-bar {
            position: absolute;
            bottom: 0;
            width: 100%;
            background: rgba(0,0,0,0.8);
            padding: 0.5rem 1rem;
            display: flex;
            justify-content: space-between;
            font-size: 0.9rem;
        }
        .live-chat {
            background: var(--card-bg);
            padding: 1.5rem;
            border-radius: 8px;
            display: flex;
            flex-direction: column;
        }
        .chat-box {
            flex-grow: 1;
            border: 1px solid #333;
            background: #151515;
            padding: 0.5rem;
            font-size: 0.9rem;
            height: 200px;
            overflow-y: auto;
            margin-top: 1rem;
        }
        .chat-msg { margin-bottom: 0.5rem; }
        .chat-user { color: var(--primary); font-weight: bold; }

        /* --- CATEGORIES --- */
        .section-title {
            font-size: 2rem;
            margin: 3rem 0 1.5rem 0;
            border-left: 5px solid var(--secondary);
            padding-left: 0.5rem;
        }
        .grid-4 {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 1.5rem;
        }
        .card {
            background: var(--card-bg);
            padding: 1.5rem;
            border-radius: 8px;
            transition: top ease 0.2s;
            border-top: 4px solid var(--primary);
        }
        .card h3 { margin-bottom: 0.5rem; color: var(--primary); }

        /* --- TABLE --- */
        .table-container { overflow-x: auto; }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 1rem;
            background: var(--card-bg);
            border-radius: 8px;
            overflow: hidden;
        }
        th, td {
            padding: 1rem;
            text-align: left;
            border-bottom: 1px solid #333;
        }
        th { background-color: #2a2a2a; color: var(--primary); }
        tr:hover { background-color: #252525; }
        .rating { color: var(--primary); font-weight: bold; }

        /* --- FOOTER / NEWSLETTER --- */
        .newsletter {
            background: linear-gradient(45deg, #1e1e1e, #2d2d2d);
            padding: 3rem;
            text-align: center;
            border-radius: 8px;
            margin-top: 4rem;
        }
        .newsletter input [type="email"] {
            padding: 0.8rem;
            width: 300px;
            max-width: 100%;
            border: none;
            border-radius: 5px;
            margin-right: 0.5rem;
        }
        footer {
            text-align: center;
            padding: 2rem;
            margin-top: 4rem;
            font-size: 0.8rem;
            color: var(--text-muted);
            border-top: 1px solid #222;
        }
    </style>
</head>
<body>

    <header>
        <div class="container">
            <h1>The Daily Crunch</h1>
            <p>Deep-Fried Drama. Extra Sauce. No Regrets.</p>
            <div class="hero-buttons">
                <a href="#" class="btn btn-primary">Watch Latest Episode</a>
                <a href="#" class="btn btn-secondary">Explore The Map</a>
                <a href="#" class="btn btn-secondary">Submit A Joint</a>
            </div>
        </div>
    </header>

    <main class="container">
        
        <h2 class="section-title">Streaming Now: Season 4, Episode 6</h2>
        <h3>"The Billion-Calorie Midnight Run"</h3>
        <div class="featured-grid">
            <div class="video-player">
                <div class="play-btn">▶</div>
                <p style="color: var(--text-muted);">Click to play episode</p>
                <div class="video-bar">
                    <span>01:24 / 42:15</span>
                    <span style="color: var(--secondary);">● LIVE STREAMING</span>
                </div>
            </div>
            <div class="live-chat">
                <h4>🔴 Live Chat (12.4k)</h4>
                <div class="chat-box">
                    <div class="chat-msg"><span class="chat-user">BurgerKing99:</span> THAT SAUCE LOOKS SPICY!!</div>
                    <div class="chat-msg"><span class="chat-user">FryGuy_Leo:</span> I've actually been there, it rules.</div>
                    <div class="chat-msg"><span class="chat-user">MunchieQueen:</span> Order the secret menu item next!</div>
                    <div class="chat-msg"><span class="chat-user">DietStartsTomorrow:</span> RIP to his stomach layout lol</div>
                </div>
            </div>
        </div>

        <h2 class="section-title">Binge-Worthy Categories</h2>
        <div class="grid-4">
            <div class="card">
                <h3>🏆 The Ultimate Fry-Off</h3>
                <p>We test every single french fry in the country to crown the absolute king of crisp.</p>
            </div>
            <div class="card">
                <h3>🤫 Secret Menu Sabotage</h3>
                <p>Ordering items that corporate fast-food chains don't want you to know exist.</p>
            </div>
            <div class="card">
                <h3>🏪 Gas Station Gourmet</h3>
                <p>Can you actually get a 5-star meal next to a fuel pump? (Spoiler: Yes).</p>
            </div>
            <div class="card">
                <h3>🌶️ The Scoville Showdown</h3>
                <p>Watch famous guests cry tears of pure joy—and pain—over hyper-spicy local specials.</p>
            </div>
        </div>

        <h2 class="section-title">📍 The Fast-Food Hotspot Map</h2>
        <p style="color: var(--text-muted); margin-bottom: 1rem;">Never have a bad cheat meal again. Here is where we've been:</p>
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Region</th>
                        <th>Featured Spot</th>
                        <th>Must-Order Item</th>
                        <th>Crunch Rating</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><b>West Coast</b></td>
                        <td>In-N-Out (Secret Location)</td>
                        <td>4x4 Flying Dutchman (Animal Style)</td>
                        <td class="rating">9.2 / 10</td>
                    </tr>
                    <tr>
                        <td><b>Midwest</b></td>
                        <td>Culver's (Chicago, IL)</td>
                        <td>Double Beef ButterBurger with Cheese</td>
                        <td class="rating">9.5 / 10</td>
                    </tr>
                    <tr>
                        <td><b>South</b></td>
                        <td>Whataburger (Austin, TX)</td>
                        <td>Honey BBQ Chicken Strip Sandwich</td>
                        <td class="rating">8.9 / 10</td>
                    </tr>
                    <tr>
                        <td><b>East Coast</b></td>
                        <td>Shake Shack (New York, NY)</td>
                        <td>Hot Ones Spicy Shackmeister</td>
                        <td class="rating">9.0 / 10</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="newsletter">
            <h2>📬 Join the Crunch Club</h2>
            <p style="color: var(--text-muted); margin-bottom: 1.5rem;">Get secret menu hacks, local recommendations, and exclusive bloopers every Friday.</p>
            <form onsubmit="event.preventDefault(); alert('Welcome to the Crunch Club!');">
                <input type="email" placeholder="Enter your email address..." required style="padding: 0.8rem; width: 280px; border-radius: 4px; border: none; margin-right: 0.5rem;">
                <button type="submit" class="btn btn-primary">Sign Me Up</button>
            </form>
        </div>

    </main>

    <footer>
        <p>© 2026 The Daily Crunch & Munchie Media Network. Parental discretion advised if you are on a strict diet.</p>
    </footer>

</body>
</html>
